---
import BaseLayout from '../layouts/BaseLayout.astro';
import { websiteSchema, organizationSchema } from '../lib/schema';
import { getCities, getCategories } from '../lib/data';

const cities = getCities();
const categories = getCategories();

const jsonLd = [websiteSchema(), organizationSchema()];
---
<BaseLayout title="Things to do with kids in Australia" description="Discover the best family activities, events, and places to go with kids." jsonLd={jsonLd}>
  <main style="padding: 40px; max-width: 800px; margin: 0 auto;">
    <h1>Things to do with kids</h1>
    
    <section>
      <h2>Browse by City</h2>
      <ul>
        {cities.map(city => (
          <li><a href={`/${city.slug}/`}>{city.title}</a></li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>
