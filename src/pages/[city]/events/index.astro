---
import CityShell from '../../../components/CityShell.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCities, getUpcomingEventsForCity, getCityBySlug } from '../../../lib/data';
import { collectionPageSchema, itemListSchema, breadcrumbSchema } from '../../../lib/schema';

export function getStaticPaths() {
  const paths: { params: { city: string } }[] = [];
  getCities().forEach(city => {
    if (getUpcomingEventsForCity(city.slug).length > 0) {
      paths.push({ params: { city: city.slug } });
    }
  });
  return paths;
}

const { city } = Astro.params;
const cityData = getCityBySlug(city as string);
const events = getUpcomingEventsForCity(city as string);
const title = `Kids events in ${cityData?.title || city}`;
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: cityData?.title || (city as string), href: `/${city}/` },
  { label: "Events" }
];

const visibleItems = events.map(item => ({
  name: item.title,
  url: `/${city}/events/${item.slug}/`
}));

const jsonLd = [
  collectionPageSchema(title, "Find the best upcoming family events.", `/${city}/events/`),
  itemListSchema(visibleItems),
  breadcrumbSchema(breadcrumbs)
];
---
<CityShell citySlug={city as string} title={title} description="Find the best upcoming family events." jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbs} />
  <h1>Upcoming Events</h1>
  <ul>
    {events.map(e => (
      <li><a href={`/${city}/events/${e.slug}/`}>{e.title}</a> ({e.start_date})</li>
    ))}
  </ul>
</CityShell>
