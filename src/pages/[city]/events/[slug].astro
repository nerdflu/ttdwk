---
import CityShell from "../../../components/CityShell.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import RelatedLinks from "../../../components/RelatedLinks.astro";
import { getApprovedEvents, getCityBySlug } from "../../../lib/data";
import { isEventUpcoming } from "../../../lib/dates";
import { eventSchema, breadcrumbSchema } from "../../../lib/schema";

export function getStaticPaths() {
  const allEvents = getApprovedEvents();
  const upcomingEvents = allEvents.filter(event => {
    const cityData = getCityBySlug(event.city);
    return isEventUpcoming(event, cityData?.timezone);
  });
  
  return upcomingEvents.map(event => ({
    params: { city: event.city, slug: event.slug },
    props: { event }
  }));
}

const { city } = Astro.params;
const { event } = Astro.props;
const cityData = getCityBySlug(city as string);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: cityData?.title || (city as string), href: `/${city}/` },
  { label: "Events", href: `/${city}/events/` },
  { label: event.title }
];

const jsonLd = [
  eventSchema(event, cityData),
  breadcrumbSchema(breadcrumbs)
];
---
<CityShell citySlug={city as string} title={event.title} description={event.summary} jsonLd={jsonLd}>
  <Breadcrumbs items={breadcrumbs} />
  <h1>{event.title}</h1>
  <p>{event.summary}</p>
  <p><strong>Date:</strong> {event.start_date}</p>
  
  <RelatedLinks citySlug={city as string} cityName={cityData?.title || (city as string)} />
</CityShell>
